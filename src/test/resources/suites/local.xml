<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="MultiBank Local Smoke" verbose="1" parallel="false">
    <listeners>
        <listener class-name="com.multibank.framework.utilities.RetryAnnotationTransformer"/>
        <listener class-name="com.multibank.framework.reporting.TestListener"/>
    </listeners>
    <test name="DWeb Local Smoke">
        <parameter name="platform" value="dweb"/>
        <packages>
            <package name="com.multibank.tests.common"/>
            <package name="com.multibank.tests.home"/>
            <package name="com.multibank.tests.explore"/>
            <package name="com.multibank.tests.company"/>
            <package name="com.multibank.tests.error"/>
        </packages>
    </test>
</suite>
